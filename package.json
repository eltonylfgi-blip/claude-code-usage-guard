{
  "name": "claude-code-usage-guard",
  "version": "0.4.0",
  "description": "A zero-dependency Claude Code plugin that warns before plan limits and celebrates fresh 5h/weekly quota windows. Network stays off unless optional ntfy is configured.",
  "type": "module",
  "bin": {
    "usage-guard": "lib/engine.mjs"
  },
  "scripts": {
    "usage": "node lib/engine.mjs",
    "test": "node tests/selftest.mjs && node tests/reset-coach.test.mjs"
  },
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "claude-code-hooks",
    "usage",
    "tokens",
    "budget",
    "rate-limit",
    "notifications"
  ],
  "license": "MIT",
  "author": "eltonylfgi-blip",
  "repository": {
    "type": "git",
    "url": "https://github.com/eltonylfgi-blip/claude-code-usage-guard"
  },
  "engines": {
    "node": ">=18"
  }
}
